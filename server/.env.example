# ─────────────────────────────────────────────────────────────────────────────
# CycleTogether server — environment variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below
# 3. NEVER commit the real .env to git (it contains your private key)
#
# WHERE TO GET THESE VALUES
# ─────────────────────────
# Firebase Console → Project Settings → Service Accounts
# → "Generate new private key" → download the JSON file
# The fields below map directly to keys in that JSON file.
# ─────────────────────────────────────────────────────────────────────────────

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id

# Paste the full private key including the -----BEGIN/END----- lines.
# Keep it on ONE LINE — use \n for newlines, e.g.:
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nPASTE_YOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id

# ─── Server settings ──────────────────────────────────────────────────────────

# HTTP port (default 3000)
PORT=3000

# Cron schedule for the daily partner notification push (default = 9am UTC).
# Uses standard cron syntax: "minute hour day-of-month month day-of-week"
# Examples:
#   0 9 * * *   → 9:00 am UTC  (default)
#   0 7 * * *   → 7:00 am UTC
#   0 18 * * *  → 6:00 pm UTC
CRON_SCHEDULE=0 9 * * *
